# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/itech-digitals

# ─── Frontend URL (CORS) ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Gmail SMTP (Required for email sending) ──────────────────────────────────
# HOW TO SET UP (2 minutes):
#  1. Go to https://myaccount.google.com/apppasswords
#  2. Sign in to your Gmail: itechkw.business@gmail.com
#  3. Select "Mail" as the App and "Windows Computer" as the Device
#  4. Click "Generate" — copy the 16-character password (e.g. abcd efgh ijkl mnop)
#  5. Paste it below WITHOUT spaces (e.g. abcdefghijklmnop)
#
SMTP_USER=itechkw.business@gmail.com
SMTP_PASS=your_16_char_app_password_here

# ─── Notification Recipient ───────────────────────────────────────────────────
# All new bookings & contact form leads will be emailed to this address
NOTIFY_EMAIL=itechkw.business@gmail.com

# ─── Admin API Key ────────────────────────────────────────────────────────────
# Used to view all leads via GET /api/contact (add header: x-admin-key)
ADMIN_KEY=change_this_to_a_secret_key
